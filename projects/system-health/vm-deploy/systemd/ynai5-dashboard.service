[Unit]
Description=YNAI5 Dashboard (FastAPI/uvicorn)
After=network.target

[Service]
Type=simple
User=shema
WorkingDirectory=/ynai5_runtime/dashboard
EnvironmentFile=/ynai5_runtime/.env
ExecStart=/usr/local/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5
StandardOutput=append:/ynai5_runtime/logs/dashboard.log
StandardError=append:/ynai5_runtime/logs/dashboard.log

[Install]
WantedBy=multi-user.target
